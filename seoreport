<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
  <title>SEO-Optimiser | Advanced Flaw Detection</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js">
  </script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      background: linear-gradient(145deg, #eef4f8 0%, #dce8f2 100%);
      font-family: 'Segoe UI', Roboto, system-ui, -apple-system, sans-serif;
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 2rem 1rem;
    }
    .glass-card {
      max-width: 1100px;
      width: 100%;
      background: rgba(255, 255, 255, 0.78);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      background: rgba(255, 255, 255, 0.9);
      border-radius: 2.5rem;
      box-shadow: 0 35px 60px rgba(0, 15, 30, 0.2), inset 0 2px 6px rgba(255,255,255,0.7);
      padding: 2rem 2rem 2.2rem;
      border: 1px solid rgba(255,255,255,0.6);
    }
    h1 {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 700;
      font-size: 2.3rem;
      color: #092c3a;
      margin-bottom: 0.2rem;
      flex-wrap: wrap;
    }
    h1 .brand-icon { font-size: 2.5rem; }
    h1 span {
      background: #155063;
      color: white;
      font-size: 1rem;
      padding: 0.25rem 1.2rem;
      border-radius: 30px;
      margin-left: 0.5rem;
      font-weight: 600;
    }
    .subtitle {
      color: #1d4859;
      margin-bottom: 1.4rem;
      font-weight: 500;
      border-left: 4px solid #1a7f7c;
      padding-left: 1rem;
    }
    .search-panel {
      display: flex;
      gap: 0.8rem;
      margin-bottom: 1.4rem;
      flex-wrap: wrap;
    }
    .input-wrapper {
      flex: 1;
      min-width: 260px;
      display: flex;
      align-items: center;
      background: white;
      border-radius: 3rem;
      padding: 0.1rem 0.1rem 0.1rem 1.6rem;
      box-shadow: 0 8px 18px rgba(0,0,0,0.04);
      border: 1px solid #d2e2f0;
    }
    .input-wrapper:focus-within {
      border-color: #0e7173;
      box-shadow: 0 8px 22px rgba(14,113,115,0.15);
    }
    .input-wrapper input {
      width: 100%;
      border: none;
      padding: 0.9rem 0.4rem;
      font-size: 1rem;
      background: transparent;
      outline: none;
      color: #0c2b35;
    }
    button {
      border: none;
      color: white;
      font-weight: 600;
      padding: 0.9rem 1.8rem;
      border-radius: 3rem;
      font-size: 1rem;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      cursor: pointer;
      transition: 0.2s;
      background: linear-gradient(135deg, #175c6e, #0a3e4c);
      box-shadow: 0 10px 18px -8px rgba(9,60,70,0.4);
      white-space: nowrap;
    }
    button:hover {
      background: linear-gradient(135deg, #1f7085, #0f505f);
      transform: scale(1.02);
    }
    button:disabled { opacity: 0.55; pointer-events: none; }
    .export-btn {
      background: linear-gradient(135deg, #2c604e, #174535);
    }
    .status-badge {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      margin: 0.8rem 0 1.2rem;
    }
    .loader {
      display: inline-block;
      width: 18px;
      height: 18px;
      border: 2px solid #cbd7e0;
      border-top: 2px solid #0e5862;
      border-radius: 50%;
      animation: spin 0.8s linear infinite;
    }
    @keyframes spin { 0%{transform:rotate(0deg)} 100%{transform:rotate(360deg)} }
    .score-circle {
      width: 90px;
      height: 90px;
      border-radius: 50%;
      background: radial-gradient(circle at 30% 30%, #f3fdfe, #d7ecf3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: 700;
      font-size: 2.6rem;
      color: #08343e;
      box-shadow: 0 10px 20px rgba(0,0,0,0.08);
      flex-shrink: 0;
    }
    .report-grid { display: flex; flex-direction: column; gap: 1.5rem; }
    .meta-section {
      background: #ffffffee;
      border-radius: 1.8rem;
      padding: 1.5rem;
      box-shadow: 0 12px 24px -12px rgba(0,0,0,0.08);
    }
    .section-title {
      font-weight: 650;
      color: #163d4c;
      margin-bottom: 1rem;
      font-size: 1.2rem;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
    .flaw-card {
      background: #fef9e7;
      border-left: 4px solid #c49b2b;
      padding: 0.7rem 1rem;
      border-radius: 0.8rem;
      margin: 0.5rem 0;
    }
    .pass { color: #157a4b; font-weight: 600; }
    .fail { color: #b13e3e; font-weight: 600; }
    .warn { color: #b68b2c; }
    .engine-grid {
      display: flex;
      flex-wrap: wrap;
      gap: 1rem;
      margin-top: 0.8rem;
    }
    .engine-card {
      background: #f4f9fd;
      border-radius: 1.2rem;
      padding: 1rem 1.2rem;
      flex: 1 1 160px;
      border: 1px solid #cfdfee;
    }
    .export-toolbar { display: flex; gap: 0.8rem; margin-top: 0.6rem; flex-wrap: wrap; }
    .footer-brand { text-align: right; font-size: 0.8rem; color: #5f7d8a; margin-top: 0.5rem; }
    @media print { body { background: white; } .glass-card { box-shadow: none; } button, .search-panel, .export-toolbar { display: none; } }
  </style>
</head>
<body>
<div class="glass-card" id="mainCard">
  <h1><span class="brand-icon">🎯</span> SEO-Optimiser <span>advanced flaws</span></h1>
  <div class="subtitle">Sitemap · Content quality · Thin pages · Multi-engine · Export HTML/PDF</div>

  <div class="search-panel">
    <div class="input-wrapper">
      <input type="text" id="urlInput" placeholder="Enter website URL (e.g. https://example.com)" value="https://www.wikipedia.org" autocomplete="off" />
    </div>
    <button id="analyzeBtn"><span>🔎</span> Deep Analyse</button>
  </div>

  <div id="statusArea" class="status-badge"></div>

  <div id="exportToolbar" class="export-toolbar" style="display: none;">
    <button id="exportHtmlBtn" class="export-btn"><span>📄</span> Export HTML</button>
    <button id="exportPdfBtn" class="export-btn"><span>📑</span> Export PDF</button>
  </div>

  <div id="reportContainer" style="display: none;">
    <div style="display:flex; flex-wrap:wrap; gap:1.8rem; align-items:center; margin-bottom:1.2rem;">
      <div class="score-circle" id="seoScoreDisplay">--</div>
      <div id="scoreSummary" style="flex:1;"></div>
    </div>
    <div class="report-grid" id="reportContent"></div>
    <div class="footer-brand">Generated by <strong>SEO-Optimiser</strong></div>
  </div>
  <div id="initialMessage" style="color:#456673; padding:1rem 0; font-style:italic;">
    Enter a URL and click "Deep Analyse" to detect sitemap, content & page flaws.
  </div>
</div>

<script>
(function() {
  const urlInput = document.getElementById('urlInput');
  const analyzeBtn = document.getElementById('analyzeBtn');
  const statusArea = document.getElementById('statusArea');
  const reportContainer = document.getElementById('reportContainer');
  const reportContent = document.getElementById('reportContent');
  const seoScoreDisplay = document.getElementById('seoScoreDisplay');
  const scoreSummary = document.getElementById('scoreSummary');
  const initialMessage = document.getElementById('initialMessage');
  const exportToolbar = document.getElementById('exportToolbar');

  let lastAnalysisData = null;

  function formatUrl(input) {
    let t = input.trim();
    if (!t) return null;
    if (!/^https?:\/\//i.test(t)) t = 'https://' + t;
    try { return new URL(t).href; } catch { return null; }
  }

  function getBaseUrl(url) {
    try { const u = new URL(url); return u.origin; } catch { return url; }
  }

  async function fetchWithProxy(url) {
    const proxies = [
      { name: 'allorigins', fn: async (u) => { const r = await fetch('https://api.allorigins.win/raw?url='+encodeURIComponent(u), {signal: AbortSignal.timeout(15000)}); if(!r.ok) throw new Error('fail'); return r.text(); }},
      { name: 'corsproxy', fn: async (u) => { const r = await fetch('https://corsproxy.io/?'+encodeURIComponent(u), {signal: AbortSignal.timeout(15000)}); if(!r.ok) throw new Error('fail'); return r.text(); }},
      { name: 'codetabs', fn: async (u) => { const r = await fetch('https://api.codetabs.com/v1/proxy?quest='+encodeURIComponent(u), {signal: AbortSignal.timeout(15000)}); if(!r.ok) throw new Error('fail'); return r.text(); }}
    ];
    for (let i=0; i<proxies.length; i++) {
      try {
        statusArea.innerHTML = `<div class="loader"></div> Proxy ${i+1}/3 (${proxies[i].name})...`;
        return await proxies[i].fn(url);
      } catch { if(i===proxies.length-1) throw new Error('All proxies failed.'); }
    }
  }

  async function checkSitemapRobots(baseUrl) {
    const results = { sitemapFound: false, sitemapUrl: '', robotsFound: false, robotsContent: '' };
    try {
      const robotsUrl = baseUrl + '/robots.txt';
      const robotsText = await fetchWithProxy(robotsUrl);
      results.robotsFound = true;
      results.robotsContent = robotsText.substring(0, 300);
      const sitemapMatch = robotsText.match(/Sitemap:\s*(\S+)/i);
      if (sitemapMatch) {
        results.sitemapFound = true;
        results.sitemapUrl = sitemapMatch[1].trim();
      }
    } catch {}
    if (!results.sitemapFound) {
      try {
        const sitemapUrl = baseUrl + '/sitemap.xml';
        await fetchWithProxy(sitemapUrl);
        results.sitemapFound = true;
        results.sitemapUrl = sitemapUrl;
      } catch {}
    }
    return results;
  }

  function extractMetadata(html, url) {
    const parser = new DOMParser();
    const doc = parser.parseFromString(html, 'text/html');
    const getMeta = (n, a='name') => doc.querySelector(`meta[${a}="${n}"]`)?.getAttribute('content') || '';
    const bodyText = doc.body?.textContent?.replace(/\s+/g, ' ').trim() || '';
    const wordCount = bodyText.split(/\s+/).filter(w=>w.length>1).length;
    const links = Array.from(doc.querySelectorAll('a[href]'));
    const internalLinks = links.filter(l => {
      try { return new URL(l.href, url).origin === new URL(url).origin; } catch { return false; }
    });
    const externalLinks = links.filter(l => {
      try { return new URL(l.href, url).origin !== new URL(url).origin; } catch { return false; }
    });
    const brokenLinksEstimate = links.filter(l => !l.href || l.href==='#' || l.href.startsWith('javascript:')).length;
    
    return {
      title: doc.querySelector('title')?.textContent?.trim() || '',
      metaDescription: getMeta('description'),
      metaKeywords: getMeta('keywords'),
      robots: getMeta('robots'),
      viewport: getMeta('viewport'),
      canonical: doc.querySelector('link[rel="canonical"]')?.getAttribute('href') || '',
      h1Tags: Array.from(doc.querySelectorAll('h1')).map(h=>h.textContent.trim()).filter(t=>t),
      h2Count: doc.querySelectorAll('h2').length,
      imagesWithoutAlt: Array.from(doc.querySelectorAll('img')).filter(i=>!i.getAttribute('alt')?.trim()).length,
      totalImages: doc.querySelectorAll('img').length,
      lang: doc.documentElement.lang || '',
      ogTitle: getMeta('og:title','property'),
      ogDescription: getMeta('og:description','property'),
      twitterCard: getMeta('twitter:card','property'),
      favicon: doc.querySelector('link[rel="icon"]')?.getAttribute('href') || '',
      wordCount,
      internalLinksCount: internalLinks.length,
      externalLinksCount: externalLinks.length,
      brokenLinksEstimate,
      textToHtmlRatio: html.length ? Math.round((bodyText.length / html.length)*100) : 0,
      url
    };
  }

  function analyzeContentFlaws(metadata) {
    const flaws = [];
    if (metadata.wordCount < 300) flaws.push({ severity: 'high', detail: 'Thin content: less than 300 words. Search engines prefer substantial content.' });
    if (metadata.wordCount < 600) flaws.push({ severity: 'medium', detail: 'Content length below 600 words – consider expanding for better topical authority.' });
    if (metadata.textToHtmlRatio < 10) flaws.push({ severity: 'medium', detail: `Low text-to-HTML ratio (${metadata.textToHtmlRatio}%). Too much code vs content.` });
    if (metadata.brokenLinksEstimate > 5) flaws.push({ severity: 'high', detail: `${metadata.brokenLinksEstimate} potentially broken/internal links (href="#", javascript:).` });
    if (metadata.internalLinksCount < 5) flaws.push({ severity: 'medium', detail: 'Very few internal links – weak site structure for crawling.' });
    if (!metadata.h1Tags.length) flaws.push({ severity: 'high', detail: 'Missing H1 tag – critical for content hierarchy.' });
    if (metadata.imagesWithoutAlt > 0) flaws.push({ severity: 'medium', detail: `${metadata.imagesWithoutAlt} images missing alt text – accessibility & SEO issue.` });
    return flaws;
  }

  function computeSEOScore(metadata, sitemapData, contentFlaws) {
    let score = 100;
    const details = [];
    const add = (a,s,m,d) => { details.push({aspect:a,status:s,message:m}); score -= d||0; };

    if (!metadata.title || metadata.title.length<10) add('Title','fail','Missing/too short',15);
    else if (metadata.title.length>60) add('Title','warn',`${metadata.title.length} chars`,8);
    else add('Title','pass','Optimal',0);

    if (!metadata.metaDescription) add('Meta Description','fail','Missing',18);
    else if (metadata.metaDescription.length<50||metadata.metaDescription.length>160) add('Meta Description','warn','Length issue',10);
    else add('Meta Description','pass','Good',0);

    if (!metadata.viewport?.includes('width=device-width')) add('Viewport','fail','Not responsive',12);
    else add('Viewport','pass','Responsive',0);

    if (!metadata.canonical) add('Canonical','warn','Missing',8);
    else add('Canonical','pass','Present',0);

    if (metadata.h1Tags.length===0) add('H1','fail','Missing',12);
    else if (metadata.h1Tags.length>1) add('H1','warn','Multiple H1s',7);
    else add('H1','pass','Single',0);

    if (!sitemapData.sitemapFound) { add('Sitemap','fail','Not found',15); } else { add('Sitemap','pass','Found',0); }
    if (!sitemapData.robotsFound) { add('Robots.txt','warn','Missing',6); } else { add('Robots.txt','pass','Present',0); }

    if (contentFlaws.filter(f=>f.severity==='high').length>0) score -= 12;
    if (contentFlaws.filter(f=>f.severity==='medium').length>0) score -= 8;

    return { score: Math.max(0, Math.min(100, Math.round(score))), details };
  }

  function analyzeSearchEngines(metadata) {
    const engines = [
      { name: 'Google', checks: [] },
      { name: 'Bing', checks: [] },
      { name: 'Yahoo', checks: [] },
      { name: 'DuckDuckGo', checks: [] },
      { name: 'Baidu', checks: [] },
      { name: 'Yandex', checks: [] }
    ];
    engines.forEach(e => {
      if (!metadata.title || metadata.title.length<10) e.checks.push({pass:false, msg:'Title missing/short'});
      if (!metadata.metaDescription) e.checks.push({pass:false, msg:'Meta description missing'});
      if (e.name==='Baidu' && !metadata.metaKeywords) e.checks.push({pass:false, msg:'Keywords meta important for Baidu'});
      if (e.name==='DuckDuckGo' && !metadata.ogTitle) e.checks.push({pass:false, msg:'OG tags improve visibility'});
    });
    return engines.map(e => ({ ...e, optimized: e.checks.every(c=>c.pass) }));
  }

  function renderReport(metadata, seoResult, engineResults, sitemapData, contentFlaws, url) {
    seoScoreDisplay.textContent = seoResult.score;
    seoScoreDisplay.style.color = seoResult.score>=80?'#1f7b4d':seoResult.score>=50?'#b68b2c':'#b13e3e';
    scoreSummary.innerHTML = `<strong style="font-size:1.2rem;">Score: ${seoResult.score}/100</strong><br>${seoResult.score>=80?'✅ Great':seoResult.score>=50?'⚠️ Needs work':'❌ Critical'}`;

    let html = `<div class="meta-section"><div class="section-title">📋 Metadata</div><table style="width:100%;border-collapse:collapse;">
      <tr><td style="font-weight:600;width:150px;">URL</td><td>${escapeHtml(url)}</td></tr>
      <tr><td>Title</td><td>${escapeHtml(metadata.title)||'—'}</td></tr>
      <tr><td>Description</td><td>${escapeHtml(metadata.metaDescription)||'—'}</td></tr>
      <tr><td>Word Count</td><td>${metadata.wordCount}</td></tr>
      <tr><td>Text/HTML ratio</td><td>${metadata.textToHtmlRatio}%</td></tr>
      <tr><td>Internal Links</td><td>${metadata.internalLinksCount}</td></tr>
      <tr><td>Broken Links (est)</td><td>${metadata.brokenLinksEstimate}</td></tr>
    </table></div>`;

    html += `<div class="meta-section"><div class="section-title">🗺️ Sitemap & Crawling</div>`;
    html += `<p><strong>Sitemap:</strong> ${sitemapData.sitemapFound ? '✅ Found at '+escapeHtml(sitemapData.sitemapUrl) : '❌ Not found'}</p>`;
    html += `<p><strong>Robots.txt:</strong> ${sitemapData.robotsFound ? '✅ Present' : '⚠️ Missing'}</p>`;
    if (!sitemapData.sitemapFound) html += `<div class="flaw-card">🔧 <strong>Fix:</strong> Create and submit a sitemap.xml to Google Search Console.</div>`;
    if (!sitemapData.robotsFound) html += `<div class="flaw-card">🔧 <strong>Fix:</strong> Add a robots.txt file to guide crawlers.</div>`;
    html += `</div>`;

    html += `<div class="meta-section"><div class="section-title">📝 Content Quality Flaws</div>`;
    if (contentFlaws.length===0) html += `<p class="pass">✅ No major content issues detected.</p>`;
    else contentFlaws.forEach(f => {
      html += `<div class="flaw-card"><strong>${f.severity==='high'?'🔴 High': '🟡 Medium'}:</strong> ${escapeHtml(f.detail)}</div>`;
    });
    html += `</div>`;

    html += `<div class="meta-section"><div class="section-title">🌍 Search Engine Optimization</div><div class="engine-grid">`;
    engineResults.forEach(e => {
      html += `<div class="engine-card"><strong>${e.optimized?'✅':'⚠️'} ${e.name}</strong>`;
      if (!e.optimized) e.checks.filter(c=>!c.pass).forEach(c => html += `<div style="font-size:0.85rem;color:#b13e3e;">• ${c.msg}</div>`);
      html += `</div>`;
    });
    html += `</div></div>`;

    html += `<div class="meta-section"><div class="section-title">📊 Detailed Checks</div>`;
    seoResult.details.forEach(d => {
      html += `<div style="margin:0.3rem 0;">${d.status==='pass'?'✅':d.status==='fail'?'❌':'⚠️'} <strong>${d.aspect}:</strong> ${d.message}</div>`;
    });
    html += `</div>`;

    reportContent.innerHTML = html;
    reportContainer.style.display = 'block';
    exportToolbar.style.display = 'flex';
    initialMessage.style.display = 'none';
    lastAnalysisData = { metadata, seoResult, engineResults, sitemapData, contentFlaws, url };
  }

  function escapeHtml(t) { return String(t||'').replace(/[&<>"]/g, m=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;' })[m]); }

  async function performAnalysis() {
    const url = formatUrl(urlInput.value);
    if (!url) { statusArea.innerHTML='<span class="error-message">❌ Invalid URL</span>'; return; }
    analyzeBtn.disabled = true;
    statusArea.innerHTML = `<div class="loader"></div> Deep analysing ${escapeHtml(url)}...`;
    try {
      const baseUrl = getBaseUrl(url);
      const [html, sitemapData] = await Promise.all([
        fetchWithProxy(url),
        checkSitemapRobots(baseUrl)
      ]);
      const metadata = extractMetadata(html, url);
      const contentFlaws = analyzeContentFlaws(metadata);
      const seoResult = computeSEOScore(metadata, sitemapData, contentFlaws);
      const engineResults = analyzeSearchEngines(metadata);
      renderReport(metadata, seoResult, engineResults, sitemapData, contentFlaws, url);
      statusArea.innerHTML = `<span style="background:#e0f0e8;padding:0.3rem 1rem;border-radius:20px;">✅ Analysis complete</span>`;
    } catch (e) {
      statusArea.innerHTML = `<span class="error-message">⚠️ ${escapeHtml(e.message)}</span>`;
      reportContainer.style.display='none';
      exportToolbar.style.display='none';
    } finally { analyzeBtn.disabled = false; }
  }

  function exportHtml() {
    if (!lastAnalysisData) return;
    const { metadata, seoResult, engineResults, sitemapData, contentFlaws, url } = lastAnalysisData;
    let r = `<!DOCTYPE html><html><head><meta charset="UTF-8"><title>SEO-Optimiser Report</title>
    <style>body{font-family:sans-serif;max-width:950px;margin:2rem auto;background:#f4f9fd;padding:2rem;}
    h1{color:#0a3e4c} .score{font-size:3rem;} .flaw{background:#fef9e7;padding:.6rem;border-left:4px solid #c49b2b;margin:.4rem 0;}
    </style></head><body><h1>🎯 SEO-Optimiser Report</h1><p>${escapeHtml(url)}</p><div class="score">${seoResult.score}/100</div>
    <h2>Sitemap</h2><p>${sitemapData.sitemapFound?'✅ Found':'❌ Missing'}</p>
    <h2>Content Flaws</h2>${contentFlaws.map(f=>`<div class="flaw">${f.detail}</div>`).join('')}
    <h2>Engines</h2>${engineResults.map(e=>`<p>${e.optimized?'✅':'⚠️'} ${e.name}</p>`).join('')}
    </body></html>`;
    const blob = new Blob([r], {type:'text/html'});
    const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'seo-optimiser-report.html'; a.click();
  }

  function exportPdf() {
    if (!lastAnalysisData) return;
    html2pdf().set({ margin:0.5, filename:'seo-optimiser-report.pdf', html2canvas:{scale:2}, jsPDF:{unit:'in',format:'letter'} }).from(reportContainer).save();
  }

  analyzeBtn.addEventListener('click', performAnalysis);
  urlInput.addEventListener('keypress', e => { if (e.key==='Enter') performAnalysis(); });
  document.getElementById('exportHtmlBtn').addEventListener('click', exportHtml);
  document.getElementById('exportPdfBtn').addEventListener('click', exportPdf);
})();
</script>
</body>
</html>